   3          // --- IAP 命令定义 ---
   4          #define CMD_IDLE    0
   5          #define CMD_READ    1
   6          #define CMD_WRITE   2
   7          #define CMD_ERASE   3
   8          
   9          // --- 等待时间设置 (针对不同主频) ---
  10          // 如果你的主频在 24MHz 以下，设为 0x02 比较稳
  11          #define WT_24M      0x02 
  12          
  13          //==========================
  14          /***基础函数部分***/
  15          //==========================
  16          // 关闭 IAP，回到安全状态
  17          void IAP_Disable() {
  18   1          IAP_CONTR = 0;
  19   1          IAP_CMD = 0;
  20   1          IAP_TRIG = 0;
  21   1          IAP_ADDRH = 0xFF; // 指向非法区域防止误触发
  22   1          IAP_ADDRL = 0xFF;
  23   1      }
  24          
  25          // 从指定地址读取一个字节
  26          uint8_t EEPROM_Read(uint16_t addr){
  27   1          uint8_t dat;
  28   1          IAP_CONTR = 0x80 | WT_24M; // 开启 IAP 模块
  29   1          IAP_CMD = CMD_READ;        // 设置读取命令
  30   1          IAP_ADDRH = addr >> 8;     // 设置高8位地址
  31   1          IAP_ADDRL = addr;          // 设置低8位地址
  32   1          IAP_TRIG = 0x5A;           // 触发序列 1
  33   1          IAP_TRIG = 0xA5;           // 触发序列 2
  34   1          _nop_();                   // 必须等待
  35   1          dat = IAP_DATA;            // 读取数据
  36   1          IAP_Disable();             // 及时关闭
  37   1          return dat;
  38   1      }
  39          
  40          // 擦除一个扇区 (STC15 一个扇区是 512 字节)
  41          // 注意：写新数据前，必须先擦除！
  42          void EEPROM_SectorErase(uint16_t addr) {
  43   1          IAP_CONTR = 0x80 | WT_24M;
  44   1          IAP_CMD = CMD_ERASE;
  45   1          IAP_ADDRH = addr >> 8;
  46   1          IAP_ADDRL = addr;
  47   1          IAP_TRIG = 0x5A;
  48   1          IAP_TRIG = 0xA5;
  49   1          _nop_();
  50   1          IAP_Disable();
  51   1      }
  52          
  53          // 在指定地址写入一个字节
  54          void EEPROM_Write(uint16_t addr, uint8_t dat) {
