line level    source

   1          #include "VCC.h"
   2          
   3          /**
   4            * @brief    获取当前电池电压 (单位: mV)
   5            * @note     比如获取到3.4v显示为3400
   6            * @param    无
   7            * @retval   获取到的电压值,3.4v也就是3400
   8            */
   9          uint16_t Get_Battery_Voltage(void)
  10          {
  11   1          uint16_t adc_res = 0;
  12   1          uint32_t vcc_mv = 0;
  13   1          
  14   1          //这里的 1275 是 STC15W 系列内部基准电压的标称值 (1.275V = 1275mV)
  15   1          uint16_t bandgap_voltage = 1242; 
  16   1      
  17   1          //初始化 ADC 寄存器
  18   1          ADC_RES = 0;
  19   1          ADC_RESL = 0;
  20   1      
  21   1          //开启 ADC 电源，并选择通道 8 (内部 Bandgap 电压通道)
  22   1          // ADC_CONTR 格式: ADC_POWER | SPEED1 | SPEED0 | ADC_FLAG | ADC_START | CHS2 | CHS1 | CHS0
  23   1          // 选择通道 8 需要将 CHS3 置 1，但 15W408AS 寄存器位配置如下：
  24   1          ADC_CONTR = 0x88; // 1000 1000: 电源开, 速度最慢(540周期), 清标志, 启动位0, 通道1000(
             -8)
  25   1          
  26   1          _nop_(); _nop_(); _nop_(); _nop_(); // 等待内部通道切换稳定
  27   1      
  28   1          //启动转换
  29   1          ADC_CONTR |= 0x08; // 置 ADC_START = 1
  30   1          
  31   1          //等待转换完成
  32   1          while (!(ADC_CONTR & 0x10)); // 等待 ADC_FLAG = 1
  33   1          
  34   1          //清除完成标志
  35   1          ADC_CONTR &= ~0x10;
  36   1      
  37   1          //读取 10 位 ADC 结果 (STC15W 系列 ADC_RES 存高 8 位，ADC_RESL 存低 2 位)
  38   1          adc_res = (ADC_RES << 2) | (ADC_RESL & 0x03);
  39   1      
  40   1          //计算 VCC 电压
  41   1          // 计算公式: VCC = (Bandgap_Value * 1024) / ADC_Result
  42   1          // 使用 32 位运算防止中间值溢出
  43   1          if (adc_res > 0) 
  44   1          {
  45   2              vcc_mv = ((uint32_t)bandgap_voltage * 1024) / adc_res;
  46   2          }
  47   1          else 
  48   1          {
  49   2              vcc_mv = 0;
  50   2          }
  51   1      
  52   1          return (uint16_t)vcc_mv;
  53   1      }
