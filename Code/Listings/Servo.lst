  17   1        PT0=0;   //中断优先级等于0
  18   1        
  19   1      }
  20          
  21          //高电平t占整个周期T（20ms）的时间
  22          //舵机旋转的角度
  23          //0.5ms ---------> 0度
  24          //1ms ---------> 45度
  25          //1.5ms ---------> 90度
  26          //2ms ---------> 135度
  27          //2.5ms ---------> 180度
  28          //映射角度值
  29          void Servo_Set(unsigned char Angle){
  30   1        unsigned char ticks;  //中间变量
  31   1      
  32   1          if(Angle > 180) Angle = 180;
  33   1          // 0.5ms + Angle*(2.0ms/180)  ≈ (Angle/45+1)*0.5ms
  34   1          ticks = Angle / 45 + 1;       // 1~5，对应 0.5~2.5ms
  35   1      
  36   1          ET0 = 0;
  37   1          Actual = ticks;
  38   1          ET0 = 1;
  39   1      }
  40          
  41          
  42          //中断函数
  43          void Timer0_Routine(void) interrupt 1
  44          {
  45   1          static unsigned char cnt = 0;
  46   1      
  47   1          TL0 = 0x33;
  48   1          TH0 = 0xFE;
  49   1      
  50   1        //采用首尾置位的方式减小cpu负担
  51   1          // 周期开始：拉高
  52   1          if(cnt == 0)
  53   1              PWM_IO = 1;
  54   1      
C51 COMPILER V9.60.7.0   SERVO                                                             04/07/2026 16:04:01 PAGE 2   

  55   1          // 到了应该结束高电平的位置：拉低
  56   1          if(cnt == Actual)
  57   1              PWM_IO = 0;
  58   1      
  59   1          cnt++;
  60   1          if(cnt >= 40)      // 40*0.5ms=20ms
  61   1              cnt = 0;
  62   1      }


