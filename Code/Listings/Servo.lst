   1          #include <stc15.h>  // 或者 #include "stc15.h"
   2          
   3          //全局变量区
   4          sbit PWM_IO=P1^3;
   5          unsigned char Actual=0;
   6          
   7          void Servo_Init(){
   8   1        //初始化定时器
   9   1        TMOD &= 0xF0;   //设置定时器模式
  10   1        TMOD |= 0x01;   //设置定时器模式
  11   1        TL0 = 0x18;   //设置定时初值
  12   1        TH0 = 0xFC;   //设置定时初值
  13   1        TF0 = 0;    //清除TF0标志
