line level    source

   1          #include <stc15w408as.H>
   2          
   3          // --- 参数计算 (假设 Fosc = 12MHz, 12T模式) ---
   4          // PCA时钟频率 = 12MHz / 12 = 2MHz (每个tick 1微秒)
   5          // 周期 20ms 所需的 tick 数 = 20,000us / 1us = 20,000
   6          // 假设高电平时间(占空比)为 3000 个计数周期，总周期为 40000 个计数周期
   7          unsigned int duty_ticks = 0;      //占空比(微秒)
   8          unsigned int period_ticks = 20000;    //总周期(微秒)
   9          
  10          //全局变量区
  11          sbit PWM_PIN=P1^1;  //需要翻转电平的端口(PWM输出口)
  12          
  13          void PCA_Init(void)
  14          {
  15   1          //管脚配置
  16   1          P_SW1 &= ~(0x30);           //切换到第一组管脚,只是为了增加鲁棒性
  17   1      
  18   1          //PCA 基础配置
  19   1          CCON = 0x00;                // 停止PCA计数，清除所有中断标志
  20   1          CL = 0x00;                  // 总计数器清零
  21   1          CH = 0x00;
  22   1          CMOD = 0x00;                // CPS2~CPS0=000 (时钟源为 Fosc/12), 允许PCA中断
  23   1      
  24   1          //通道0配置：负责【占空比】(到达此值时拉低电平) ---
  25   1          CCAP0L = duty_ticks;        // 初次赋值后，中断里无需再修改
  26   1          CCAP0H = duty_ticks >> 8;
  27   1          CCAPM0 = 0x49;              // 16位软件定时模式，允许比较，允许中断
  28   1      
  29   1          //通道1配置：负责【总周期】(到达此值时拉高电平并清零总计数) ---
  30   1          CCAP1L = period_ticks;      // 初次赋值后，中断里无需再修改
  31   1          CCAP1H = period_ticks >> 8;
  32   1          CCAPM1 = 0x49;              // 16位软件定时模式，允许比较，允许中断
  33   1      
  34   1          //启动设置 ---
  35   1          PWM_PIN = 1;                // 初始状态置高电平
  36   1          CR = 1;                     // 启动 PCA 计数器
  37   1          EA = 1;                     // 打开 CPU 总中断
  38   1      }
  39          
  40          
  41          
  42          // PCA 中断服务函数
  43          void PCA_ISR(void) interrupt 7
  44          {
  45   1          // --- 通道0中断：到达占空比时间，拉低电平 ---
  46   1          if (CCF0)
  47   1          {
  48   2              CCF0 = 0;       // 清空中断标志位
  49   2              PWM_PIN = 0;    // 输出低电平
  50   2          }
  51   1      
  52   1          // --- 通道1中断：到达总周期时间，拉高电平并清空计数器 ---
  53   1          if (CCF1)
  54   1          {
C51 COMPILER V9.60.7.0   SERVO                                                             05/07/2026 19:10:52 PAGE 2   

  55   2              CCF1 = 0;       // 清空中断标志位
  56   2              PWM_PIN = 1;    // 输出高电平
  57   2              
  58   2              // 核心要求：清零总计数器，重新开始新一轮周期
  59   2              // 建议：清零时短暂关闭一下 CR，防止在清零 CL 和 CH 的间隙发生硬件进位
             -计数，清零后再打开
  60   2              CR = 0;  
  61   2              CL = 0;
  62   2              CH = 0;
  63   2            
  64   2              //重新设置占空比
  65   2              CCAP0L = duty_ticks;
  66   2              CCAP0H = duty_ticks >> 8;
  67   2            
  68   2              CR = 1;
  69   2          }
  70   1      }
  71          
  72          
  73          
  74          //高电平t占整个周期T（20ms）的时间
  75          //舵机旋转的角度
  76          //0.5ms ---------> 0度
  77          //1ms ---------> 45度
  78          //1.5ms ---------> 90度
  79          //2ms ---------> 135度
  80          //2.5ms ---------> 180度
  81          //映射角度值
  82          void Servo_Set(unsigned char Angle){
  83   1      
  84   1          if(Angle > 180) Angle = 180;
  85   1          duty_ticks=(Angle/45+1)*500;
  86   1      }


