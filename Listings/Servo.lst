line level    source

   1          #include <REGX52.H>
   2          
   3          //全局变量区
   4          sbit PWM_IO=P1^3;
   5          unsigned char Actual=0;
   6          
   7          void Servo_Init(){
   8   1              //初始化定时器
   9   1              TMOD &= 0xF0;           //设置定时器模式
  10   1              TMOD |= 0x01;           //设置定时器模式
  11   1              TL0 = 0x18;             //设置定时初值
  12   1              TH0 = 0xFC;             //设置定时初值
  13   1              TF0 = 0;                //清除TF0标志
  14   1              TR0 = 1;                //定时器0开始计时
  15   1              ET0=1;  //允许中断（没做解释，自行了解）
  16   1              EA=1;   //允许总中断
  17   1              PT0=0;   //中断优先级等于0
  18   1              
  19   1      }
  20          
  21          //高电平t占整个周期T（20ms）的时间
  22          //舵机旋转的角度
  23          //0.5ms ---------> 0度
  24          //1ms ---------> 45度
  25          //1.5ms ---------> 90度
  26          //2ms ---------> 135度
  27          //2.5ms ---------> 180度
  28          //映射角度值
  29          void Servo_Set(unsigned char Angle){
  30   1              Actual=Angle/45+1;
  31   1      }
  32          
  33          
  34          //中断函数
  35          void Timer0_Routine() interrupt 1
  36          {
  37   1              static  unsigned int T0Count;
  38   1              TL0 = 0x33;             //设置定时初值
  39   1              TH0 = 0xFE;             //设置定时初值
  40   1              
  41   1              T0Count++;
  42   1              if(T0Count>=40)  //20毫秒,每次500微秒，40次20毫秒
  43   1              {
  44   2                      T0Count=0;
  45   2              }
  46   1              
  47   1              if(Actual>T0Count){
  48   2                      PWM_IO=1;
  49   2              }else{
  50   2                      PWM_IO=0;
  51   2              }
  52   1      }


